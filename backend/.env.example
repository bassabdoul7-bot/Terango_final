# =====================================================
# TeranGO Backend Environment Variables
# =====================================================

# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/terango?retryWrites=true&w=majority

# Redis Configuration (for real-time driver locations)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Secret (generate a random string)
JWT_SECRET=your-jwt-secret-here-change-in-production

# SMS Configuration (Orange SMS API or Twilio)
SMS_API_KEY=your-sms-api-key
SMS_API_SECRET=your-sms-api-secret
SMS_SENDER_ID=TeranGO

# Payment Configuration
# Orange Money
ORANGE_MONEY_API_KEY=your-orange-money-api-key
ORANGE_MONEY_API_SECRET=your-orange-money-secret
ORANGE_MONEY_MERCHANT_ID=your-merchant-id

# Wave
WAVE_API_KEY=your-wave-api-key
WAVE_API_SECRET=your-wave-secret

# Google Maps API
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Telegram Alerts
TELEGRAM_BOT_TOKEN=8259630845:AAHgV30lqjcU0KiHyQqI87un-BFF0UUbSPw
TELEGRAM_CHAT_ID=8460600516

# Email (for password reset etc.)
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-email-password

# Redis URL (alternative to REDIS_HOST/PORT/PASSWORD)
REDIS_URL=

# Commission Rates (percentage)
PLATFORM_COMMISSION_RATE=12
PARTNER_COMMISSION_RATE=3

# CORS - comma-separated allowed origins (leave empty for *)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006,http://localhost:19007

# App URLs
RIDER_APP_URL=http://localhost:19006
DRIVER_APP_URL=http://localhost:19007
ADMIN_DASHBOARD_URL=http://localhost:3000
