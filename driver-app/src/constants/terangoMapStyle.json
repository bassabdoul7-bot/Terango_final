{
  "version": 8,
  "name": "TeranGO",
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "tiles": ["https://tiles.terango.sn/senegal/{z}/{x}/{y}.mvt"],
      "minzoom": 0,
      "maxzoom": 15
    }
  },
  "glyphs": "https://demotiles.maplibre.org/font/{fontstack}/{range}.pbf",
  "layers": [

    {"id": "earth", "type": "fill", "source": "openmaptiles", "source-layer": "earth", "paint": {"fill-color": "#FAF3E8"}},
    {"id": "landuse-park", "type": "fill", "source": "openmaptiles", "source-layer": "landuse", "filter": ["in", "kind", "park", "garden", "playground", "national_park", "nature_reserve"], "paint": {"fill-color": "#D4E8B0", "fill-opacity": 0.7}},
    {"id": "landuse-residential", "type": "fill", "source": "openmaptiles", "source-layer": "landuse", "filter": ["in", "kind", "residential", "neighbourhood"], "paint": {"fill-color": "#F5EDE0", "fill-opacity": 0.5}},
    {"id": "landuse-commercial", "type": "fill", "source": "openmaptiles", "source-layer": "landuse", "filter": ["in", "kind", "commercial", "retail", "industrial"], "paint": {"fill-color": "#F0E0C8", "fill-opacity": 0.5}},
    {"id": "landuse-school", "type": "fill", "source": "openmaptiles", "source-layer": "landuse", "filter": ["in", "kind", "school", "university", "college"], "paint": {"fill-color": "#FFF3D6", "fill-opacity": 0.6}},
    {"id": "landuse-hospital", "type": "fill", "source": "openmaptiles", "source-layer": "landuse", "filter": ["in", "kind", "hospital"], "paint": {"fill-color": "#FCE4E4", "fill-opacity": 0.6}},
    {"id": "water", "type": "fill", "source": "openmaptiles", "source-layer": "water", "paint": {"fill-color": "#5BB8C4"}},
    {"id": "water-label", "type": "symbol", "source": "openmaptiles", "source-layer": "water", "filter": ["has", "name"], "minzoom": 8, "layout": {"text-field": ["coalesce", ["get", "name:fr"], ["get", "name"]], "text-font": ["Noto Sans Bold"], "text-size": 14}, "paint": {"text-color": "#2E8A96", "text-halo-color": "#FFFFFF", "text-halo-width": 1.5}},
    {"id": "buildings", "type": "fill", "source": "openmaptiles", "source-layer": "buildings", "minzoom": 13, "paint": {"fill-color": "#E0D4C0", "fill-opacity": 0.8, "fill-outline-color": "#C8B89C"}},
    {"id": "road-path", "type": "line", "source": "openmaptiles", "source-layer": "roads", "filter": ["==", "kind", "path"], "paint": {"line-color": "#D4C8B0", "line-width": 0.8, "line-dasharray": [2, 2]}},
    {"id": "road-minor", "type": "line", "source": "openmaptiles", "source-layer": "roads", "filter": ["all", ["==", "kind", "minor_road"], ["in", "kind_detail", "residential", "unclassified", "service"]], "layout": {"line-cap": "round"}, "paint": {"line-color": "#ffffff", "line-width": {"stops": [[12, 1], [14, 3.5], [16, 7]]}}},
    {"id": "road-tertiary", "type": "line", "source": "openmaptiles", "source-layer": "roads", "filter": ["all", ["==", "kind", "minor_road"], ["in", "kind_detail", "tertiary", "tertiary_link"]], "layout": {"line-cap": "round"}, "paint": {"line-color": "#ffffff", "line-width": {"stops": [[10, 1.5], [14, 5], [16, 9]]}}},
    {"id": "road-secondary-outline", "type": "line", "source": "openmaptiles", "source-layer": "roads", "filter": ["all", ["==", "kind", "major_road"], ["in", "kind_detail", "secondary", "secondary_link"]], "layout": {"line-cap": "round"}, "paint": {"line-color": "#C8B89C", "line-width": {"stops": [[10, 2.5], [14, 5.5], [16, 10]]}}},
    {"id": "road-secondary", "type": "line", "source": "openmaptiles", "source-layer": "roads", "filter": ["all", ["==", "kind", "major_road"], ["in", "kind_detail", "secondary", "secondary_link"]], "layout": {"line-cap": "round"}, "paint": {"line-color": "#DDD0B8", "line-width": {"stops": [[10, 1.5], [14, 4], [16, 8]]}}},
    {"id": "road-primary-outline", "type": "line", "source": "openmaptiles", "source-layer": "roads", "filter": ["all", ["==", "kind", "major_road"], ["in", "kind_detail", "primary", "primary_link"]], "layout": {"line-cap": "round"}, "paint": {"line-color": "#6ab840", "line-width": {"stops": [[8, 2], [12, 4.5], [16, 10]]}}},
    {"id": "road-primary", "type": "line", "source": "openmaptiles", "source-layer": "roads", "filter": ["all", ["==", "kind", "major_road"], ["in", "kind_detail", "primary", "primary_link"]], "layout": {"line-cap": "round"}, "paint": {"line-color": "#8ED55A", "line-width": {"stops": [[8, 1], [12, 3], [16, 8]]}}},
    {"id": "road-highway-outline", "type": "line", "source": "openmaptiles", "source-layer": "roads", "filter": ["==", "kind", "highway"], "layout": {"line-cap": "round"}, "paint": {"line-color": "#006030", "line-width": {"stops": [[6, 2], [10, 4.5], [16, 12]]}}},
    {"id": "road-highway", "type": "line", "source": "openmaptiles", "source-layer": "roads", "filter": ["==", "kind", "highway"], "layout": {"line-cap": "round"}, "paint": {"line-color": "#00853F", "line-width": {"stops": [[6, 1], [10, 3], [16, 10]]}}},
    {"id": "road-label", "type": "symbol", "source": "openmaptiles", "source-layer": "roads", "minzoom": 11, "filter": ["has", "name"], "layout": {"text-field": ["coalesce", ["get", "name:fr"], ["get", "name"]], "text-font": ["Noto Sans Bold"], "text-size": {"stops": [[11, 12], [13, 14], [15, 15], [16, 16]]}, "symbol-placement": "line", "text-max-angle": 30, "text-padding": 5}, "paint": {"text-color": "#3A2818", "text-halo-color": "#FFFFFF", "text-halo-width": 2}},
    {"id": "building-label", "type": "symbol", "source": "openmaptiles", "source-layer": "buildings", "minzoom": 14, "filter": ["has", "addr_housenumber"], "layout": {"text-field": "{addr_housenumber}", "text-font": ["Noto Sans Bold"], "text-size": 14, "text-allow-overlap": false}, "paint": {"text-color": "#6B5B4A", "text-halo-color": "#ffffff", "text-halo-width": 1}},
    {"id": "poi-hospital", "type": "symbol", "source": "openmaptiles", "source-layer": "pois", "minzoom": 13, "filter": ["in", "kind", "hospital", "clinic", "pharmacy"], "layout": {"text-field": ["coalesce", ["get", "name:fr"], ["get", "name"]], "text-font": ["Noto Sans Bold"], "text-size": 14, "text-offset": [0, 1.2]}, "paint": {"text-color": "#c43030", "text-halo-color": "#ffffff", "text-halo-width": 1.5}},
    {"id": "poi-school", "type": "symbol", "source": "openmaptiles", "source-layer": "pois", "minzoom": 14, "filter": ["in", "kind", "school", "university", "college", "kindergarten"], "layout": {"text-field": ["coalesce", ["get", "name:fr"], ["get", "name"]], "text-font": ["Noto Sans Bold"], "text-size": 14, "text-offset": [0, 1.2]}, "paint": {"text-color": "#8B6914", "text-halo-color": "#ffffff", "text-halo-width": 1.5}},
    {"id": "poi-worship", "type": "symbol", "source": "openmaptiles", "source-layer": "pois", "minzoom": 14, "filter": ["in", "kind", "place_of_worship", "mosque"], "layout": {"text-field": ["coalesce", ["get", "name:fr"], ["get", "name"]], "text-font": ["Noto Sans Bold"], "text-size": 14, "text-offset": [0, 1.2]}, "paint": {"text-color": "#7B5EA7", "text-halo-color": "#ffffff", "text-halo-width": 1.5}},
    {"id": "poi-shop", "type": "symbol", "source": "openmaptiles", "source-layer": "pois", "minzoom": 15, "filter": ["in", "kind", "shop", "supermarket", "marketplace", "mall"], "layout": {"text-field": ["coalesce", ["get", "name:fr"], ["get", "name"]], "text-font": ["Noto Sans Bold"], "text-size": 14, "text-offset": [0, 1.2]}, "paint": {"text-color": "#2D8B57", "text-halo-color": "#ffffff", "text-halo-width": 1.5}},
    {"id": "poi-food", "type": "symbol", "source": "openmaptiles", "source-layer": "pois", "minzoom": 15, "filter": ["in", "kind", "restaurant", "cafe", "fast_food", "bar"], "layout": {"text-field": ["coalesce", ["get", "name:fr"], ["get", "name"]], "text-font": ["Noto Sans Bold"], "text-size": 14, "text-offset": [0, 1.2]}, "paint": {"text-color": "#c47020", "text-halo-color": "#ffffff", "text-halo-width": 1.5}},
    {"id": "poi-transport", "type": "symbol", "source": "openmaptiles", "source-layer": "pois", "minzoom": 13, "filter": ["in", "kind", "bus_stop", "station", "bus_station", "ferry_terminal", "aerodrome"], "layout": {"text-field": ["coalesce", ["get", "name:fr"], ["get", "name"]], "text-font": ["Noto Sans Bold"], "text-size": 14, "text-offset": [0, 1.2]}, "paint": {"text-color": "#2068a0", "text-halo-color": "#ffffff", "text-halo-width": 1.5}},
    {"id": "poi-general", "type": "symbol", "source": "openmaptiles", "source-layer": "pois", "minzoom": 15, "filter": ["!in", "kind", "hospital", "clinic", "pharmacy", "school", "university", "college", "kindergarten", "place_of_worship", "mosque", "shop", "supermarket", "marketplace", "mall", "restaurant", "cafe", "fast_food", "bar", "bus_stop", "station", "bus_station", "ferry_terminal", "aerodrome"], "layout": {"text-field": ["coalesce", ["get", "name:fr"], ["get", "name"]], "text-font": ["Noto Sans Bold"], "text-size": 14, "text-offset": [0, 1.2]}, "paint": {"text-color": "#6B5B4A", "text-halo-color": "#ffffff", "text-halo-width": 1}},
    {"id": "place-village", "type": "symbol", "source": "openmaptiles", "source-layer": "places", "filter": ["in", "kind", "village", "hamlet"], "minzoom": 10, "layout": {"text-field": ["coalesce", ["get", "name:fr"], ["get", "name"]], "text-font": ["Noto Sans Bold"], "text-size": 14}, "paint": {"text-color": "#3A2818", "text-halo-color": "#FFFFFF", "text-halo-width": 2}},
    {"id": "place-town", "type": "symbol", "source": "openmaptiles", "source-layer": "places", "filter": ["==", "kind", "town"], "minzoom": 7, "layout": {"text-field": ["coalesce", ["get", "name:fr"], ["get", "name"]], "text-font": ["Noto Sans Bold"], "text-size": {"stops": [[7, 14], [12, 16]]}}, "paint": {"text-color": "#3A2818", "text-halo-color": "#FFFFFF", "text-halo-width": 2}},
    {"id": "place-city", "type": "symbol", "source": "openmaptiles", "source-layer": "places", "filter": ["==", "kind", "city"], "minzoom": 5, "layout": {"text-field": ["coalesce", ["get", "name:fr"], ["get", "name"]], "text-font": ["Noto Sans Bold"], "text-size": {"stops": [[5, 14], [10, 18], [14, 22]]}, "text-transform": "uppercase", "text-letter-spacing": 0.05}, "paint": {"text-color": "#3A2818", "text-halo-color": "#FFFFFF", "text-halo-width": 2.5}},
    {"id": "place-neighbourhood", "type": "symbol", "source": "openmaptiles", "source-layer": "places", "filter": ["in", "kind", "neighbourhood", "suburb", "quarter"], "minzoom": 12, "layout": {"text-field": ["coalesce", ["get", "name:fr"], ["get", "name"]], "text-font": ["Noto Sans Bold"], "text-size": {"stops": [[12, 14], [15, 16]]}, "text-transform": "uppercase", "text-letter-spacing": 0.08}, "paint": {"text-color": "#5C4428", "text-halo-color": "#FFFFFF", "text-halo-width": 1.5}}
  ]
}


